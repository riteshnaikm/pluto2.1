# Copy to .env and fill in values

# Required in production
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development
SESSION_COOKIE_SECURE=false

# Admin bootstrap (first deploy)
DEFAULT_ADMIN_EMAIL=admin@yourcompany.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LLM providers (set at least one)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_PROVIDER=gemini

# Vector DB
PINECONE_API_KEY=

# Upload limit (MB)
MAX_UPLOAD_MB=10

# Auth: comma-separated email domains allowed for Google OAuth (* = any)
ALLOWED_EMAIL_DOMAINS=peoplelogic.in

# Security (optional)
ENABLE_CSP=false

# Upload cleanup: flask cleanup-uploads or scripts/cleanup_uploads.py
UPLOAD_CLEANUP_MAX_AGE_DAYS=7
UPLOAD_CLEANUP_DRY_RUN=false

# Performance (optional)
FAST_EVAL_MODE=false
EVALUATION_CACHE_ENABLED=true
HANDBOOK_GROQ_REASONING_EFFORT=medium
EVALUATION_MAX_COMPLETION_TOKENS=2048

# VoxPro telephony (internal network)
VOXPRO_OFFICE_BASE=http://office.peoplelogic.in
VOXPRO_LOG_PULL_URL=http://office.peoplelogic.in/Voxpro/api/log_pull
VOXPRO_LOOKBACK_DAYS=365
VOXPRO_MIN_DUR_SECONDS=5
# Optional cap on total call duration (seconds) sent to Groq STT per run; 0 = unlimited
# VOXPRO_STT_MAX_TOTAL_DUR_SECONDS=540
CALL_TRANSCRIPTION_PROVIDER=groq
CALL_TRANSCRIPTION_GROQ_MODEL=whisper-large-v3-turbo
CALL_ANALYSIS_MODEL_PROVIDER=groq
CALL_ANALYSIS_GROQ_MODEL=llama-3.3-70b-versatile
CALL_ANALYSIS_MAX_TRANSCRIPT_CHARS=12000
CALL_ANALYSIS_MAX_COMPLETION_TOKENS=2048
CALL_MERGE_MAX_BYTES=24000000
CALL_MERGE_MAX_DURATION_SEC=5400
# FFMPEG_BINARY=C:\Users\<you>\AppData\Local\Microsoft\WinGet\Links\ffmpeg.exe

# PeopleLogic Recorder — client call transcripts (GCS)
# Place service-account JSON in project root (gitignored); path is relative to repo root.
GOOGLE_APPLICATION_CREDENTIALS=gen-lang-client-0915725474-55a8fe2509e9.json
GCS_BUCKET=peoplelogic-pl-recordings
GCS_PREFIX=pl-recorder
