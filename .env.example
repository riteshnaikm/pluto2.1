# Copy to .env and fill in values

# Required in production
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development
SESSION_COOKIE_SECURE=false

# Admin bootstrap (first deploy)
DEFAULT_ADMIN_EMAIL=admin@yourcompany.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LLM providers (set at least one)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_PROVIDER=gemini

# Vector DB
PINECONE_API_KEY=

# Upload limit (MB)
MAX_UPLOAD_MB=10

# Auth: comma-separated email domains allowed for Google OAuth (* = any)
ALLOWED_EMAIL_DOMAINS=peoplelogic.in

# Security (optional)
ENABLE_CSP=false

# Upload cleanup: flask cleanup-uploads or scripts/cleanup_uploads.py
UPLOAD_CLEANUP_MAX_AGE_DAYS=7
UPLOAD_CLEANUP_DRY_RUN=false

# Performance (optional)
FAST_EVAL_MODE=false
EVALUATION_CACHE_ENABLED=true
HANDBOOK_GROQ_REASONING_EFFORT=medium
EVALUATION_MAX_COMPLETION_TOKENS=2048
